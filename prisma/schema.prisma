generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  LAWYER
  ADMIN
}

enum LawyerType {
  ADVOCATE
  LICENSED_LAWYER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ServiceType {
  VIDEO
  AUDIO
  WRITTEN
  DOC_REVIEW
}

enum BookingMode {
  INSTANT
  REQUEST
}

enum BookingStatus {
  PENDING_PAYMENT
  REQUESTED
  CONFIRMED
  DECLINED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  CAPTURED
  PARTIALLY_REFUNDED
  REFUNDED
}

model User {
  id            String         @id @default(cuid())
  role          UserRole       @default(CLIENT)
  phone         String?        @unique
  email         String?        @unique
  fullName      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lawyerProfile LawyerProfile?
  sessions      Session[]
  bookings      Booking[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model OtpCode {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
}

model PracticeArea {
  id        String               @id @default(cuid())
  slug      String               @unique
  nameAz    String
  nameEn    String?
  sortOrder Int                  @default(0)
  lawyers   LawyerPracticeArea[]
}

model LawyerProfile {
  id                 String               @id @default(cuid())
  userId             String               @unique
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               LawyerType
  verificationStatus VerificationStatus   @default(PENDING)
  slug               String?              @unique
  rejectionReason    String?
  reviewedAt         DateTime?
  licenseNo          String?
  bio                String?
  yearsExperience    Int?
  city               String               @default("Bakı")
  bufferMin          Int                  @default(0)
  bookingMode        BookingMode          @default(REQUEST)
  languages          String[]             @default(["az"])
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  practiceAreas      LawyerPracticeArea[]
  services           Service[]
  availabilityRules  AvailabilityRule[]
  bookings           Booking[]
}

model LawyerPracticeArea {
  lawyerProfileId String
  practiceAreaId  String
  lawyerProfile   LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)
  practiceArea    PracticeArea  @relation(fields: [practiceAreaId], references: [id], onDelete: Cascade)

  @@id([lawyerProfileId, practiceAreaId])
}

model Service {
  id          String        @id @default(cuid())
  lawyerId    String
  lawyer      LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  type        ServiceType
  durationMin Int?
  priceQepik  Int
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([lawyerId])
}

model AvailabilityRule {
  id       String        @id @default(cuid())
  lawyerId String
  lawyer   LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  weekday  Int
  startMin Int
  endMin   Int

  @@index([lawyerId, weekday])
}

model Booking {
  id            String        @id @default(cuid())
  clientId      String
  client        User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lawyerId      String
  lawyer        LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  serviceId     String
  serviceType   ServiceType
  durationMin   Int
  priceQepik    Int
  startAt       DateTime
  endAt         DateTime
  status        BookingStatus @default(PENDING_PAYMENT)
  activeSlotKey String?       @default("A")
  payment       Payment?
  session       ConsultSession?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([lawyerId, startAt, activeSlotKey])
  @@index([clientId, startAt])
  @@index([lawyerId, startAt])
}

model Payment {
  id          String        @id @default(cuid())
  bookingId   String        @unique
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider    String
  amountQepik   Int
  refundedQepik Int           @default(0)
  status        PaymentStatus
  createdAt   DateTime      @default(now())
}

model ConsultSession {
  id              String    @id @default(cuid())
  bookingId       String    @unique
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomName        String
  consentClientAt DateTime?
  consentLawyerAt DateTime?
  clientJoinedAt  DateTime?
  lawyerJoinedAt  DateTime?
  endedAt         DateTime?
  createdAt       DateTime  @default(now())
}
