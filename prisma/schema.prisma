generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  LAWYER
  ADMIN
}

enum LawyerType {
  ADVOCATE
  LICENSED_LAWYER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ServiceType {
  VIDEO
  AUDIO
  WRITTEN
  DOC_REVIEW
}

enum BookingMode {
  INSTANT
  REQUEST
}

enum BookingStatus {
  PENDING_PAYMENT
  REQUESTED
  CONFIRMED
  DECLINED
  CANCELLED
  COMPLETED
}

enum DisputeStatus {
  OPEN
  RESPONDED
  RESOLVED
}

enum DisputeResolution {
  FULL_REFUND
  PARTIAL_REFUND
  DISMISSED
}

enum PaymentStatus {
  CAPTURED
  PARTIALLY_REFUNDED
  REFUNDED
}

model User {
  id            String         @id @default(cuid())
  role          UserRole       @default(CLIENT)
  phone         String?        @unique
  email         String?        @unique
  fullName      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lawyerProfile LawyerProfile?
  sessions      Session[]
  bookings      Booking[]
  messages      Message[]
  notifications Notification[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model OtpCode {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
}

model PracticeArea {
  id        String               @id @default(cuid())
  slug      String               @unique
  nameAz    String
  nameEn    String?
  sortOrder Int                  @default(0)
  lawyers   LawyerPracticeArea[]
}

model LawyerProfile {
  id                 String               @id @default(cuid())
  userId             String               @unique
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               LawyerType
  verificationStatus VerificationStatus   @default(PENDING)
  slug               String?              @unique
  rejectionReason    String?
  reviewedAt         DateTime?
  licenseNo          String?
  licenseDocKey      String?
  idDocKey           String?
  bio                String?
  yearsExperience    Int?
  city               String               @default("Bakı")
  bufferMin          Int                  @default(0)
  bookingMode        BookingMode          @default(REQUEST)
  languages          String[]             @default(["az"])
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  practiceAreas      LawyerPracticeArea[]
  services           Service[]
  availabilityRules  AvailabilityRule[]
  bookings           Booking[]
  reviews            Review[]
}

model LawyerPracticeArea {
  lawyerProfileId String
  practiceAreaId  String
  lawyerProfile   LawyerProfile @relation(fields: [lawyerProfileId], references: [id], onDelete: Cascade)
  practiceArea    PracticeArea  @relation(fields: [practiceAreaId], references: [id], onDelete: Cascade)

  @@id([lawyerProfileId, practiceAreaId])
}

model Service {
  id          String        @id @default(cuid())
  lawyerId    String
  lawyer      LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  type        ServiceType
  durationMin Int?
  priceQepik  Int
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([lawyerId])
}

model AvailabilityRule {
  id       String        @id @default(cuid())
  lawyerId String
  lawyer   LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  weekday  Int
  startMin Int
  endMin   Int

  @@index([lawyerId, weekday])
}

model Booking {
  id            String        @id @default(cuid())
  clientId      String
  client        User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lawyerId      String
  lawyer        LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  serviceId     String
  serviceType   ServiceType
  durationMin   Int
  priceQepik    Int
  startAt       DateTime
  endAt         DateTime
  status        BookingStatus @default(PENDING_PAYMENT)
  activeSlotKey String?       @default("A")
  rescheduledCount Int        @default(0)
  reminded24At  DateTime?
  reminded1At   DateTime?
  payment       Payment?
  session       ConsultSession?
  messages      Message[]
  review        Review?
  dispute       Dispute?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([lawyerId, startAt, activeSlotKey])
  @@index([clientId, startAt])
  @@index([lawyerId, startAt])
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String?       @unique
  booking       Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  docOrderId    String?       @unique
  docOrder      DocOrder?     @relation(fields: [docOrderId], references: [id], onDelete: Cascade)
  provider      String
  amountQepik   Int
  refundedQepik Int           @default(0)
  status        PaymentStatus
  createdAt     DateTime      @default(now())
}

model ConsultSession {
  id              String    @id @default(cuid())
  bookingId       String    @unique
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomName        String
  consentClientAt DateTime?
  consentLawyerAt DateTime?
  clientJoinedAt  DateTime?
  lawyerJoinedAt  DateTime?
  endedAt         DateTime?
  egressId        String?
  recordingKey    String?
  recordingStartedAt DateTime?
  createdAt       DateTime  @default(now())
}

model Message {
  id             String   @id @default(cuid())
  bookingId      String
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  attachmentKey  String?
  attachmentName String?
  flagged        Boolean  @default(false)
  flagReasons    String[] @default([])
  createdAt      DateTime @default(now())

  @@index([bookingId, createdAt])
  @@index([flagged, createdAt])
}

model Review {
  id         String        @id @default(cuid())
  bookingId  String        @unique
  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  lawyerId   String
  lawyer     LawyerProfile @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  clientId   String
  stars      Int
  tags       String[]      @default([])
  text       String?
  lawyerReply String?
  repliedAt  DateTime?
  hidden     Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([lawyerId, hidden, createdAt])
}

model Dispute {
  id                String             @id @default(cuid())
  bookingId         String             @unique
  booking           Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  clientId          String
  reason            String
  description       String
  lawyerResponse    String?
  lawyerRespondedAt DateTime?
  status            DisputeStatus      @default(OPEN)
  resolution        DisputeResolution?
  refundQepik       Int                @default(0)
  resolvedAt        DateTime?
  overdueNotifiedAt DateTime?
  createdAt         DateTime           @default(now())

  @@index([status, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  link      String?
  readAt    DateTime?
  emailedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model DocTemplate {
  id            String            @id @default(cuid())
  slug          String            @unique
  titleAz       String
  descriptionAz String
  category      String
  priceQepik    Int               @default(0)
  active        Boolean           @default(true)
  sortOrder     Int               @default(0)
  versions      TemplateVersion[]
  createdAt     DateTime          @default(now())
}

model TemplateVersion {
  id         String      @id @default(cuid())
  templateId String
  template   DocTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version    Int
  bodyText   String
  fields     Json
  published  Boolean     @default(true)
  createdAt  DateTime    @default(now())
  orders     DocOrder[]

  @@unique([templateId, version])
}

enum DocOrderStatus {
  PENDING_PAYMENT
  PAID
}

model DocOrder {
  id                String          @id @default(cuid())
  userId            String
  templateVersionId String
  templateVersion   TemplateVersion @relation(fields: [templateVersionId], references: [id])
  answersEncrypted  String
  status            DocOrderStatus  @default(PENDING_PAYMENT)
  priceQepik        Int
  docUid            String          @unique
  pdfKey            String?
  payment           Payment?
  paidAt            DateTime?
  createdAt         DateTime        @default(now())

  @@index([userId, createdAt])
}
