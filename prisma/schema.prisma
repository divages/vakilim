generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  LAWYER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  role      UserRole @default(CLIENT)
  phone     String?  @unique
  email     String?  @unique
  fullName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}